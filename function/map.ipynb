   ],
   "source": [
    "numbers = [1, 2, 3]\n",
    "result = map(str, numbers)\n",
    "\n",
    "print(result)\n",
    "print(list(result))    # 전체 값을 확인하려면 list나 tuple로 형변환을 해줘야 함"
   ]
  }
